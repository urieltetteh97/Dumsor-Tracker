rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Reports validation
    function isValidReport(data) {
      return data.location is string && data.location.size() <= 200 &&
             data.region is string && data.region.size() <= 50 &&
             data.type in ['OUTAGE', 'UNEXPECTED_ON'] &&
             data.description is string && data.description.size() <= 1000 &&
             data.timestamp == request.time &&
             data.reporterId == request.auth.uid;
    }

    match /reports/{reportId} {
      allow read: if true; // Publicly readable to see outages
      allow create: if isSignedIn() && isValidId(reportId) && isValidReport(incoming());
      allow update, delete: if false; // Reports are immutable for now
    }

    // User preferences validation
    function isValidPreference(data) {
      return data.userId == request.auth.uid &&
             data.region is string && data.region.size() <= 50 &&
             data.group in ['A', 'B', 'C'] &&
             data.notificationsEnabled is bool;
    }

    match /userPreferences/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidPreference(incoming());
      allow delete: if isOwner(userId);
    }
  }
}
